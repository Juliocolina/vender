# Environment Variables Template
# Copy this file to .env.local for local development
# NEVER commit .env.local to version control

# Next.js
NEXT_PUBLIC_APP_NAME=VENDER
#NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Configuration
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
# NEXT_PUBLIC_API_KEY=your_api_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Auth
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Google OAuth for Supabase
# Obtén estas credenciales en https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email (if applicable)
# EMAIL_SERVER=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=user@example.com
# EMAIL_PASSWORD=your_email_password

# Analytics
# NEXT_PUBLIC_GA_TRACKING_ID=your_ga_tracking_id

# Feature flags
# NEXT_PUBLIC_ENABLE_FEATURE_X=true

# IMPORTANT: For production, use Vercel Environment Variables or similar secure storage
# Do not store real secrets in this file