# Security configuration for npm
engine-strict=true
fund=false
audit=true
audit-level=moderate
package-lock=true
save-exact=true
scripts-prepend-node-path=true

# Registry configuration (use default)
# registry=https://registry.npmjs.org/

# Disable sending usage data to npm
send-metrics=false

# Enable package signatures verification
sign-git-commit=true
sign-git-tag=true

# Strict peer dependencies
legacy-peer-deps=false

# Disable interactive prompts
yes=false